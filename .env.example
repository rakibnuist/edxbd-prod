# === Security (REQUIRED in production) ===
# Generate a strong secret, e.g.:  openssl rand -base64 48
# The app REFUSES to run in production without a JWT_SECRET of 32+ chars.
JWT_SECRET=

# Admin bootstrap. On first login with ADMIN_EMAIL, the account is created once
# with ADMIN_PASSWORD (bcrypt-hashed). Change the password after first login.
# Leave ADMIN_PASSWORD blank once the admin user exists.
ADMIN_EMAIL=admin@eduexpressint.com
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# === Integrations ===
META_ACCESS_TOKEN=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_SITE_URL=https://eduexpressint.com
NEXT_PUBLIC_SITE_NAME=EduExpress International
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GTM_ID=
MONGODB_URI=
